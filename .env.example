# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=sq_user
POSTGRES_PASSWORD=change_me_strong_password

# ─── Backend ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_64_char_random_hex

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ANTHROPIC_API_KEY=sk-ant-your_key_here

ALLOWED_ORIGINS=https://smartquran.app,https://www.smartquran.app
ENVIRONMENT=production

# ─── Frontend (baked into Docker image at build time) ────────────────────────
NEXT_PUBLIC_API_URL=https://smartquran.app
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
